# PUABO OS v2.0.0 Environment Variables

# Application Configuration
VITE_APP_NAME="PUABO OS"
VITE_APP_VERSION="2.0.0"
VITE_APP_DESCRIPTION="Creator Operating System"

# API Configuration
VITE_API_URL="http://localhost:3001"
VITE_API_TIMEOUT=10000

# Authentication (for future backend integration)
VITE_JWT_SECRET="your-super-secret-jwt-key-here"
VITE_SESSION_TIMEOUT=3600000

# Database (for future backend integration)
DATABASE_URL="postgresql://username:password@localhost:5432/puabo_os"
REDIS_URL="redis://localhost:6379"

# Payment Integration (for future Stripe integration)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_key_here"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Email Service (for future email integration)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SENDGRID_API_KEY="your-sendgrid-api-key"

# Storage (for future file uploads)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="puabo-os-uploads"

# Social Media Integration (for future features)
YOUTUBE_API_KEY="your-youtube-api-key"
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

# Analytics (for future analytics integration)
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
MIXPANEL_TOKEN="your-mixpanel-token"

# Development
NODE_ENV="development"
VITE_DEBUG=true
VITE_LOG_LEVEL="debug"

# Production
# NODE_ENV="production"
# VITE_DEBUG=false
# VITE_LOG_LEVEL="error"